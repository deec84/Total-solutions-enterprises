# Copy this file to .env for local Docker Compose only. Never commit .env.

# Backend application
PARKSHIELD_ENVIRONMENT=local
PARKSHIELD_LOG_LEVEL=INFO
PARKSHIELD_API_V1_PREFIX=/api/v1
PARKSHIELD_JWT_SECRET=replace-with-a-random-string-at-least-32-characters
PARKSHIELD_ACCESS_TOKEN_TTL_MINUTES=15
PARKSHIELD_REFRESH_TOKEN_TTL_DAYS=30
PARKSHIELD_DATABASE_URL=postgresql+asyncpg://parkshield:replace-with-local-db-password@postgres:5432/parkshield

# Email verification and recovery. Empty values use the local in-memory adapter.
PARKSHIELD_SMTP_HOST=
PARKSHIELD_SMTP_PORT=587
PARKSHIELD_SMTP_USERNAME=
PARKSHIELD_SMTP_PASSWORD=
PARKSHIELD_EMAIL_FROM=no-reply@parkshield.example
PARKSHIELD_MOBILE_LINK_SCHEME=parkshield

# Optional local provider adapters. Staging and production require HTTPS URLs and tokens.
PARKSHIELD_PUSH_PROVIDER_URL=
PARKSHIELD_PUSH_PROVIDER_TOKEN=
PARKSHIELD_TOW_PROVIDER_URL=
PARKSHIELD_TOW_PROVIDER_TOKEN=

# Optional locally. Deployed environments require a private KMS-encrypted bucket.
PARKSHIELD_MEDIA_BUCKET=
PARKSHIELD_MEDIA_RETENTION_DAYS=30

# Public policy identifier recorded with every optional-consent decision.
PARKSHIELD_PRIVACY_POLICY_VERSION=2026-07-17

# Disabled until source rights and a municipal feed are approved.
PARKSHIELD_MUNICIPAL_IMPORTS_ENABLED=false
PARKSHIELD_MUNICIPAL_MAX_UPLOAD_BYTES=5242880

# Store purchases remain disabled until Apple/Google products and a verification gateway exist.
PARKSHIELD_BILLING_ENABLED=false
PARKSHIELD_BILLING_SUBJECT_SECRET=replace-with-an-independent-random-secret-at-least-32-characters
PARKSHIELD_BILLING_GATEWAY_URL=
PARKSHIELD_BILLING_GATEWAY_TOKEN=
PARKSHIELD_APPLE_PREMIUM_PRODUCT_ID=
PARKSHIELD_GOOGLE_PREMIUM_PRODUCT_ID=

# Privacy-safe telemetry. Local memory providers make no network calls. External
# exporters remain off until an HTTPS collector, egress allowlist, and staging gate exist.
PARKSHIELD_OBSERVABILITY_PROVIDER=memory
PARKSHIELD_OBSERVABILITY_EXPORT_ENABLED=false
PARKSHIELD_OBSERVABILITY_OTLP_ENDPOINT=
PARKSHIELD_OBSERVABILITY_SERVICE_NAME=parkshield-api

# Product analytics is opt-in at both deployment and user-consent layers.
PARKSHIELD_PRODUCT_ANALYTICS_ENABLED=false
PARKSHIELD_PRODUCT_ANALYTICS_PROVIDER=disabled
PARKSHIELD_PRODUCT_ANALYTICS_SUBJECT_SECRET=change-me-to-an-independent-random-secret-at-least-32-characters
PARKSHIELD_PRODUCT_ANALYTICS_RETENTION_DAYS=30

# Docker Compose host ports and PostgreSQL bootstrap values
PARKSHIELD_API_PORT=8000
PARKSHIELD_POSTGRES_PORT=5432
PARKSHIELD_POSTGRES_DB=parkshield
PARKSHIELD_POSTGRES_USER=parkshield
PARKSHIELD_POSTGRES_PASSWORD=replace-with-local-db-password
