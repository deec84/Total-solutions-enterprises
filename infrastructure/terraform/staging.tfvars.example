environment   = "staging"
aws_region    = "us-east-1"
image_uri     = "123456789012.dkr.ecr.us-east-1.amazonaws.com/parkshield-api@sha256:replace"
desired_count = 1
municipal_imports_enabled = false # Change only after source-rights and staging-import approval.
municipal_max_upload_bytes = 5242880
billing_enabled = false # Requires approved sandbox products and verification-gateway evidence.
observability_provider       = "memory" # Switch only with an injected, tested OTLP adapter.
observability_export_enabled = false
observability_otlp_endpoint  = ""
product_analytics_enabled    = false # Requires privacy/legal approval and explicit user consent.
product_analytics_provider   = "disabled"
product_analytics_retention_days = 30
alarm_email   = "platform-alerts@example.com"
smtp_host     = "smtp.example.com"
smtp_username = "replace-with-service-account"
smtp_password_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:parkshield/staging/smtp-password-replace"
push_provider_url = "https://push-gateway.example.com/v1/messages"
push_provider_token_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:parkshield/staging/push-token-replace"
tow_provider_url = "https://tow-gateway.example.com/v1/lookup"
tow_provider_token_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:parkshield/staging/tow-token-replace"
provider_egress_cidrs = ["203.0.113.10/32", "198.51.100.20/32"]
origin_domain_name = "origin-staging.parkshield.example"
route53_zone_id = "ZREPLACEWITHHOSTEDZONEID"
origin_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/replace"
